# Redirect HTTP to HTTPS (standard production rule)
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Block sensitive extensions
<FilesMatch "\.(sqlite|db|sql|xlsx|py|zip|md|env)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to migrate_to_mysql.php
<Files "migrate_to_mysql.php">
    Order allow,deny
    Deny from all
</Files>

# Deny public access to scratch files
RedirectMatch 403 /scratch/.*

# Security Headers Configuration
<IfModule mod_headers.c>
    # Prevents clickjacking attacks by blocking iframe rendering
    Header set X-Frame-Options "SAMEORIGIN"

    # Protects against MIME-sniffing vulnerability
    Header set X-Content-Type-Options "nosniff"

    # Enables the Cross-Site Scripting filter (often built into browsers)
    Header set X-XSS-Protection "1; mode=block"

    # Defines referrer behavior
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # Restricts API usage permissions
    Header set Permissions-Policy "geolocation=(), camera=(), microphone=()"

    # Strict-Transport-Security (HSTS) to prevent SSL stripping
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Content Security Policy (CSP) allowing only trusted local and CDN resources
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://unpkg.com; img-src 'self' data:; connect-src 'self';"
</IfModule>
